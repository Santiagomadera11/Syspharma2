import React, { useState, useEffect } from "react";
import { X, Save, Calendar, Clock, User, FileText, Phone, Mail, AlertCircle } from "lucide-react";
import { appointmentService } from "../services/appointmentService";

const AppointmentFormModal = ({
  isOpen,
  onClose,
  onSave,
  appointment,
  doctors,
  availabilityService,
}) => {
  const [formData, setFormData] = useState({
    paciente: "",
    documento: "",
    telefono: "",
    correo: "",
    doctorId: "",
    fecha: "",
    hora: "",
    servicio: "",
    valor: "",
    notas: "",
  });

  const [errors, setErrors] = useState({});
  const [availableSlots, setAvailableSlots] = useState([]);
  const [services, setServices] = useState([]);
  const [selectedServiceId, setSelectedServiceId] = useState("");

  useEffect(() => {
    if (appointment) {
      setFormData({
        paciente: appointment.paciente || "",
        documento: appointment.documento || "",
        telefono: appointment.telefono || "",
        correo: appointment.correo || "",
        doctorId: appointment.doctorId || "",
        fecha: appointment.fecha || "",
        hora: appointment.hora || "",
        servicio: appointment.servicio || "",
        valor: appointment.valor || "",
        notas: appointment.notas || "",
      });
    } else {
      setFormData({
        paciente: "",
        documento: "",
        telefono: "",
        correo: "",
        doctorId: "",
        fecha: "",
        hora: "",
        servicio: "",
        valor: "",
        notas: "",
      });
    }
    setErrors({});
    // set selected service if appointment matches an existing service
    try {
      const svcList = JSON.parse(localStorage.getItem("sys_services") || "[]");
      const found = (svcList || []).find((s) => s.nombre === (appointment?.servicio || ""));
      setSelectedServiceId(found ? found.id : "");
    } catch (e) {
      setSelectedServiceId("");
    }
  }, [appointment, isOpen, doctors]);

  useEffect(() => {
    try {
      const svcList = JSON.parse(localStorage.getItem("sys_services") || "[]");
      setServices(Array.isArray(svcList) ? svcList : []);
    } catch (e) {
      setServices([]);
    }
  }, []);

  // Cuando cambia el médico o la fecha, actualizar slots disponibles
  useEffect(() => {
    if (formData.doctorId && formData.fecha) {
      const slots = availabilityService.getAvailableSlotsForDate(
        formData.doctorId,
        formData.fecha,
      );
      setAvailableSlots(slots);
    } else {
      setAvailableSlots([]);
    }
  }, [formData.doctorId, formData.fecha, availabilityService]);

  // Validaciones
  const validateField = (name, value) => {
    let error = "";

    switch (name) {
      case "paciente":
        if (!value.trim()) {
          error = "El nombre es requerido";
        } else if (!/^[a-záéíóúñA-ZÁÉÍÓÚÑ\s]+$/.test(value)) {
          error = "El nombre solo debe contener letras";
        }
        break;

      case "documento":
        if (value && !/^\d+$/.test(value)) {
          error = "El documento solo debe contener números";
        }
        break;

      case "telefono":
        if (value && !/^\d+$/.test(value)) {
          error = "El teléfono solo debe contener números";
        }
        break;

      case "correo":
        if (value && !value.includes("@")) {
          error = "El correo debe contener el símbolo @";
        }
        break;

      case "servicio":
        if (!value.trim()) {
          error = "El servicio es requerido";
        } else if (!/^[a-záéíóúñA-ZÁÉÍÓÚÑ\s]+$/.test(value)) {
          error = "El servicio solo debe contener letras";
        }
        break;

      default:
        break;
    }

    return error;
  };

  const handleInputChange = (field, value) => {
    setFormData({ ...formData, [field]: value });
    const error = validateField(field, value);
    setErrors({ ...errors, [field]: error });
  };

  const handleDoctorChange = (e) => {
    const doctorId = parseInt(e.target.value);
    const doctor = doctors.find((d) => d.id === doctorId);
    setFormData({
      ...formData,
      doctorId: doctorId,
      servicio: doctor ? `Consulta con ${doctor.especialidad}` : "",
    });
  };

  const handleServiceSelect = (e) => {
    const id = e.target.value;
    setSelectedServiceId(id);
    if (!id) return;
    const svc = services.find((s) => String(s.id) === String(id));
    if (svc) {
      setFormData((prev) => ({
        ...prev,
        servicio: svc.nombre || prev.servicio,
        valor: svc.precio || prev.valor,
      }));
    }
  };

  const handleSubmit = (e) => {
    e.preventDefault();

    // Validar todos los campos
    let newErrors = {};
    newErrors.paciente = validateField("paciente", formData.paciente);
    newErrors.documento = validateField("documento", formData.documento);
    newErrors.telefono = validateField("telefono", formData.telefono);
    newErrors.correo = validateField("correo", formData.correo);
    newErrors.servicio = validateField("servicio", formData.servicio);

    setErrors(newErrors);

    // Validar campos obligatorios
    if (
      !formData.paciente ||
      !formData.doctorId ||
      !formData.fecha ||
      !formData.hora ||
      !formData.servicio
    ) {
      alert("Por favor complete todos los campos obligatorios");
      return;
    }

    // Validar que no haya errores
    if (Object.values(newErrors).some((error) => error)) {
      alert("Por favor corrija los errores en el formulario");
      return;
    }

    const appointmentData = {
      ...formData,
      doctorId: parseInt(formData.doctorId),
    };

    if (appointment) {
      // Actualizar cita existente
      appointmentService.updateAppointment(appointment.id, appointmentData);
    } else {
      // Crear nueva cita
      appointmentService.createAppointment(appointmentData);
    }

    onSave();
  };

  if (!isOpen) return null;

  return (
    <div className="fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm flex items-center justify-center z-50">
      <div className="bg-white rounded-xl p-4 max-w-4xl w-full mx-4 max-h-[90vh]">
        <div className="flex items-center justify-between mb-4">
          <h2 className="text-xl font-bold text-gray-800">
            {appointment ? "Editar Cita" : "Nueva Cita"}
          </h2>
          <button
            onClick={onClose}
            className="text-gray-400 hover:text-gray-600"
          >
            <X size={24} />
          </button>
        </div>

        <div className="max-h-[78vh] overflow-auto pr-2">
        <form onSubmit={handleSubmit} className="space-y-3 text-sm">
          {/* Información del Paciente */}
          <div className="grid grid-cols-1 md:grid-cols-2 gap-2">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">
                Nombre del Paciente *
              </label>
              <div className="relative">
                <User
                  className="absolute left-2 top-1/2 -translate-y-1/2 text-gray-400"
                  size={14}
                />
                <input
                  type="text"
                  required
                  className={`w-full pl-7 pr-2 py-1 border rounded-lg focus:outline-none focus:ring-1 text-sm ${
                    errors.paciente
                      ? "border-red-500 focus:ring-red-300"
                      : "border-gray-200 focus:ring-blue-300"
                  }`}
                  placeholder="Nombre completo"
                  value={formData.paciente}
                  onChange={(e) => handleInputChange("paciente", e.target.value)}
                />
              </div>
              {errors.paciente && (
                <div className="flex items-center gap-1 mt-1 text-red-500 text-xs">
                  <AlertCircle size={12} />
                  {errors.paciente}
                </div>
              )}
            </div>

            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">
                Documento *
              </label>
              <input
                type="text"
                required
                className={`w-full px-3 py-1.5 border rounded-lg focus:outline-none focus:ring-1 text-sm ${
                  errors.documento
                    ? "border-red-500 focus:ring-red-300"
                    : "border-gray-200 focus:ring-blue-300"
                }`}
                placeholder="Número de documento"
                value={formData.documento}
                onChange={(e) => handleInputChange("documento", e.target.value)}
              />
              {errors.documento && (
                <div className="flex items-center gap-1 mt-1 text-red-500 text-xs">
                  <AlertCircle size={12} />
                  {errors.documento}
                </div>
              )}
            </div>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-2">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">
                Teléfono
              </label>
              <div className="relative">
                <Phone
                  className="absolute left-2 top-1/2 -translate-y-1/2 text-gray-400"
                  size={14}
                />
                <input
                  type="text"
                  className={`w-full pl-8 pr-3 py-1.5 border rounded-lg focus:outline-none focus:ring-1 text-sm ${
                    errors.telefono
                      ? "border-red-500 focus:ring-red-300"
                      : "border-gray-200 focus:ring-blue-300"
                  }`}
                  placeholder="Número de teléfono"
                  value={formData.telefono}
                  onChange={(e) => handleInputChange("telefono", e.target.value)}
                />
              </div>
              {errors.telefono && (
                <div className="flex items-center gap-1 mt-1 text-red-500 text-xs">
                  <AlertCircle size={12} />
                  {errors.telefono}
                </div>
              )}
            </div>

            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">
                Correo
              </label>
              <div className="relative">
                <Mail
                  className="absolute left-2 top-1/2 -translate-y-1/2 text-gray-400"
                  size={14}
                />
                <input
                  type="text"
                  className={`w-full pl-8 pr-3 py-1.5 border rounded-lg focus:outline-none focus:ring-1 text-sm ${
                    errors.correo
                      ? "border-red-500 focus:ring-red-300"
                      : "border-gray-200 focus:ring-blue-300"
                  }`}
                  placeholder="correo@ejemplo.com"
                  value={formData.correo}
                  onChange={(e) => handleInputChange("correo", e.target.value)}
                />
              </div>
              {errors.correo && (
                <div className="flex items-center gap-1 mt-1 text-red-500 text-xs">
                  <AlertCircle size={12} />
                  {errors.correo}
                </div>
              )}
            </div>
          </div>

          {/* Profesional Médico */}
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              Profesional Médico *
            </label>
            <select
              required
              className="w-full px-3 py-1 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-300 text-sm"
              value={formData.doctorId}
              onChange={handleDoctorChange}
            >
              <option value="">Seleccionar profesional</option>
              {doctors.map((doctor) => (
                <option key={doctor.id} value={doctor.id}>
                  {doctor.nombre} - {doctor.especialidad}
                </option>
              ))}
            </select>
          </div>

          {/* Fecha y Hora */}
          <div className="grid grid-cols-1 md:grid-cols-2 gap-2">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                Fecha *
              </label>
              <div className="relative">
                <Calendar
                  className="absolute left-2 top-1/2 -translate-y-1/2 text-gray-400"
                  size={14}
                />
                <input
                  type="date"
                  required
                  className="w-full pl-8 pr-3 py-1.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-300 text-sm"
                  value={formData.fecha}
                  onChange={(e) =>
                    setFormData({ ...formData, fecha: e.target.value })
                  }
                  min={new Date().toISOString().split("T")[0]}
                />
              </div>
            </div>

            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                Hora *
              </label>
                <select
                  required
                  className="w-full px-3 py-1 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-300 text-sm"
                value={formData.hora}
                onChange={(e) =>
                  setFormData({ ...formData, hora: e.target.value })
                }
                disabled={!formData.doctorId || !formData.fecha}
              >
                <option value="">
                  {!formData.doctorId || !formData.fecha
                    ? "Seleccione médico y fecha primero"
                    : "Seleccionar hora disponible"}
                </option>
                {availableSlots.map((slot) => (
                  <option key={slot} value={slot}>
                    {slot}
                  </option>
                ))}
              </select>
            </div>
          </div>

          {/* Servicio: seleccionar de catálogo (opcional) y campo editable */}
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              Servicio (opcional)
            </label>
            <select
              className="w-full px-3 py-1 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-300 text-sm mb-2"
              value={selectedServiceId}
              onChange={handleServiceSelect}
            >
              <option value="">-- Seleccionar servicio del catálogo --</option>
              {services.map((s) => (
                <option key={s.id} value={s.id}>
                  {s.nombre} - $ {Number(s.precio).toLocaleString()}
                </option>
              ))}
            </select>

            <label className="block text-sm font-medium text-gray-700 mb-1">
              Servicio *
            </label>
            <div className="relative">
              <FileText
                className="absolute left-2 top-1/2 -translate-y-1/2 text-gray-400"
                size={14}
              />
              <input
                type="text"
                required
                className={`w-full pl-7 pr-2 py-1 border rounded-lg focus:outline-none focus:ring-1 text-sm ${
                  errors.servicio
                    ? "border-red-500 focus:ring-red-300"
                    : "border-gray-200 focus:ring-blue-300"
                }`}
                placeholder="Tipo de consulta o servicio"
                value={formData.servicio}
                onChange={(e) => {
                  // reset selected service if user types custom service
                  if (selectedServiceId) setSelectedServiceId("");
                  handleInputChange("servicio", e.target.value);
                }}
              />
            </div>
            {errors.servicio && (
              <div className="flex items-center gap-1 mt-1 text-red-500 text-xs">
                <AlertCircle size={12} />
                {errors.servicio}
              </div>
            )}
          </div>

          {/* Valor */}
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              Valor de la Cita (Pesos)
            </label>
            <div className="relative">
              <span className="absolute left-2 top-1/2 -translate-y-1/2 text-gray-400">$</span>
              <input
                type="number"
                className="w-full pl-7 pr-2 py-1 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-300 text-sm"
                placeholder="Monto en pesos"
                value={formData.valor}
                onChange={(e) => setFormData({ ...formData, valor: e.target.value })}
              />
            </div>
          </div>

          {/* Notas */}
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">
              Notas Adicionales
            </label>
            <textarea
              className="w-full px-3 py-1 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-300 text-sm"
              rows={1}
              placeholder="Observaciones adicionales..."
              value={formData.notas}
              onChange={(e) =>
                setFormData({ ...formData, notas: e.target.value })
              }
            />
          </div>

          {/* Botones */}
          <div className="flex gap-2 pt-3 border-t">
            <button
              type="button"
              onClick={onClose}
              className="flex-1 px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-md font-medium transition-colors text-sm"
            >
              Cancelar
            </button>
            <button
              type="submit"
              className="flex-1 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-md font-medium transition-colors text-sm flex items-center justify-center"
            >
              <Save size={14} className="inline mr-2" />
              {appointment ? "Actualizar" : "Crear"}
            </button>
          </div>
        </form>
      </div>
    </div>
  );
};

export default AppointmentFormModal;
